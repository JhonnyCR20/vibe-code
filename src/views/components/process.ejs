<section class="section process section-reveal">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Metodo de trabajo</p>
      <h2>Un flujo tecnico para resultados consistentes</h2>
    </div>

    <div class="timeline">
      <% page.process.forEach((item) => { %>
      <article class="timeline-item">
        <span class="step"><%= item.step %></span>
        <h3><%= item.title %></h3>
        <p><%= item.detail %></p>
      </article>
      <% }); %>
    </div>
  </div>
</section>
