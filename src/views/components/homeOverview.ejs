<section class="section section-reveal">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Navegacion por areas</p>
      <h2>Una seccion dedicada para cada etapa del servicio</h2>
    </div>

    <div class="overview-grid">
      <% page.homeHighlights.forEach((item) => { %>
      <article class="overview-card">
        <p class="overview-label"><%= item.label %></p>
        <h3><%= item.title %></h3>
        <p><%= item.description %></p>
        <a class="text-link" href="<%= item.href %>">Ir a <%= item.label %></a>
      </article>
      <% }); %>
    </div>
  </div>
</section>
